# Banco de dados PostgreSQL
DATABASE_URL="postgresql://seu_usuario:sua_senha@localhost:5432/user_system"

# Access token — curto (15 minutos)
JWT_SECRET="troque_por_string_longa_e_aleatoria"
JWT_EXPIRES_IN="15m"

# Refresh token — longo (7 dias)
REFRESH_TOKEN_SECRET="outra_string_longa_diferente_da_anterior"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development

# Frontend (para CORS)
CLIENT_URL="http://localhost:5173"

# Gmail — use uma "Senha de app" (não sua senha normal)
# Gere em: myaccount.google.com > Segurança > Senhas de app
MAIL_USER="seu@gmail.com"
MAIL_PASS="sua_senha_de_app_gmail"
MAIL_FROM="User System <seu@gmail.com>"

# URL do frontend (usada no link do e-mail)
FRONTEND_URL="http://localhost:5173"

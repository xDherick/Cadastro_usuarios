# Banco de dados — cole a connection string do Neon aqui
DATABASE_URL="postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/user_system?sslmode=require"

# Access token (15 minutos)
JWT_SECRET="cole_uma_string_longa_e_aleatoria_aqui"
JWT_EXPIRES_IN="15m"

# Refresh token (7 dias)
REFRESH_TOKEN_SECRET="cole_outra_string_diferente_aqui"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=production

# URL do frontend no Vercel — COM https:// e SEM barra no final
CLIENT_URL="https://seu-projeto.vercel.app"

# Gmail — use Senha de App (não a senha normal)
MAIL_USER="seu@gmail.com"
MAIL_PASS="sua_senha_de_app_16_caracteres"
MAIL_FROM="User System <seu@gmail.com>"

# URL do frontend para links nos e-mails
FRONTEND_URL="https://seu-projeto.vercel.app"
